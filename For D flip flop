
Design Code
module dff (
    input logic clk,
    input logic reset,   // Added reset
    input logic d,
    output logic q
);

    always_ff @(posedge clk) begin
        if (reset)
            q <= 0;      // Initialize
        else
            q <= d;
    end

endmodule

